# Copy this file to ".env" and fill in your GLM API key.
# .env is gitignored — never commit your real key.

# --- GLM (Zhipu) API key ---
# GLM Coding Plan / BigModel (China endpoint, open.bigmodel.cn):
ZHIPU_CN_API_KEY=your-glm-api-key-here

# GLM via Z.AI (international endpoint, api.z.ai) — use this slot instead if your key is a z.ai key
# and set llm.provider="glm" + the matching backend_url in config.json:
# ZHIPU_API_KEY=your-zai-api-key-here

# Note: everything else (ticker, date, model, endpoint, analysts) is in config.json — not here.
